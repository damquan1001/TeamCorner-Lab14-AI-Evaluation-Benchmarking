# Copy to .env and fill in real keys to enable live multi-judge API calls.
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional model overrides.
GEMINI_JUDGE_MODEL=gemini-3.5-flash
OPENROUTER_JUDGE_MODEL=openai/gpt-4o-mini
GEMINI_AGENT_MODEL=gemini-3.5-flash
OPENROUTER_AGENT_MODEL=openai/gpt-4o-mini
GEMINI_DATASET_MODEL=gemini-3.5-flash
OPENROUTER_DATASET_MODEL=openai/gpt-4o-mini

# Optional provider routing: auto, gemini, or openrouter.
AGENT_PROVIDER=auto
DATASET_PROVIDER=auto
